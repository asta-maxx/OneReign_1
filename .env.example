# Copy to .env. Zero-setup: SQLite needs no external database.
DATABASE_URL="file:./dev.db"

# Required for auth (JWT signing). Use any long random string locally.
JWT_SECRET="change-me-to-a-long-random-string"

# Shared invite code required to create accounts via /api/auth/signup.
INVITE_CODE="TRANSITOPS-INVITE-2026"

# Optional overrides:
# JWT_EXPIRES_IN="7d"
# AUTH_COOKIE_NAME="auth_token"
